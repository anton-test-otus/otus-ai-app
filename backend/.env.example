###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_random_secret_key_min_32_chars
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> application ###
# Порт для доступа к приложению на хосте (по умолчанию 8080 для разработки, для продакшена используйте 80)
APP_PORT=8080
# Порт для фронтенд dev server (Vite)
FRONTEND_PORT=5173
###< application ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DB_HOST=postgres
DB_PORT=5432
DB_NAME=otus_ai_db
DB_USER=otus_user
DB_PASSWORD=change_me_secure_password

DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase_min_32_chars
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> initial admin user ###
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password
###< initial admin user ###
