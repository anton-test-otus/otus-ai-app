# Шаблон для scripts/generate-env.sh (не редактировать напрямую для деплоя).
# Настройки VITE_* — в корневом .env; frontend/.env генерируется при make env / make build.

# URL бэкенд API (dev: http://localhost:8080/api; prod/demo на одном URL: /api)
VITE_API_URL=http://localhost:8080/api

# Если не задан в корневом .env — берётся из APP_AUTH_ENABLED при generate-env
VITE_AUTH_ENABLED=true

# Значения по умолчанию (если не заданы в профиле пользователя)
VITE_AUTOSAVE_DELAY_SECONDS=10
VITE_VERSION_CONSOLIDATION_WINDOW_MINUTES=5
