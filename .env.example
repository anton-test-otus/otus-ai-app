# Корневой env для docker compose (скопируйте в .env в корне репозитория).

# true — JWT, login/register; false — однопользовательский режим (prod/demo по ТЗ)
APP_AUTH_ENABLED=false

# Email единственного пользователя при APP_AUTH_ENABLED=false
SINGLE_USER_EMAIL=owner@local

# Порты на хосте (prod: один URL на APP_PORT; dev UI additionally on FRONTEND_PORT)
APP_PORT=8080
FRONTEND_PORT=5173

# PostgreSQL (должны совпадать с backend/.env)
DB_NAME=otus_ai_db
DB_USER=otus_user
DB_PASSWORD=otus_password
