# Единый env проекта (скопируйте в .env в корне репозитория).
# При сборке/деплое генерируются backend/.env (все ключи кроме VITE_*)
# и frontend/.env (только VITE_*) — см. scripts/generate-env.sh / make env

# --- Режим приложения ---
# true — JWT, login/register (по умолчанию); false — однопользовательский режим
APP_AUTH_ENABLED=true
SINGLE_USER_EMAIL=owner@local

# --- Docker (compose) ---
# demo — static SPA (:8080), c подгрузкой ассетов из CI/dist, dev — Vite hot reload (:5173)
DOCKER_ENV=demo

# Префикс имён контейнеров, образов и каталогов volumes/${APP_NAME}/…
APP_NAME=otus_ai

# --- Порты (docker compose) ---
APP_PORT=8080
FRONTEND_PORT=5173

# --- Symfony ---
APP_ENV=dev
APP_SECRET=change_me_to_random_secret_key_min_32_chars
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=otus_ai_db
DB_USER=otus_user
DB_PASSWORD=change_me_secure_password

# --- JWT (Lexik) ---
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase_min_32_chars
JWT_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000

# --- CORS ---
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# --- Администратор (app:create-admin) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# --- Настройки пользователя (defaults) ---
AUTOSAVE_DELAY_SECONDS=10
NOTE_VERSION_CONSOLIDATION_WINDOW_MINUTES=5

# --- Корзина ---
TRASH_RETENTION_DAYS=30

# --- Frontend (VITE_* → frontend/.env) ---
# dev (Vite :5173): http://localhost:8080/api ; prod/demo (один URL :8080): /api
VITE_API_URL=http://localhost:8080/api
# если не задан — берётся из APP_AUTH_ENABLED при generate-env
VITE_AUTH_ENABLED=true
VITE_AUTOSAVE_DELAY_SECONDS=10
VITE_VERSION_CONSOLIDATION_WINDOW_MINUTES=5
